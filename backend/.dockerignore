# Git
.git
.gitignore
.gitattributes

# Environment (akan di-set via Render env vars)
.env
.env.*
!.env.example

# PHP dependencies (akan di-install ulang oleh composer di Docker)
vendor/

# Node modules (stage 1 install sendiri)
node_modules/

# Laravel generated cache (akan di-generate ulang)
bootstrap/cache/*.php
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
storage/logs/*

# Build artifacts dari lokal (akan di-build ulang di Docker)
public/build/
public/hot

# Development & test files
.phpunit.cache
.phpunit.result.cache
*.log
*.sqlite
tests/

# IDE & OS files
.idea/
.vscode/
.nova/
.zed/
*.DS_Store
Thumbs.db

# Docs & delivery
README.md
